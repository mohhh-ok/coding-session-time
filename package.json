{
  "name": "cctime",
  "version": "0.1.0",
  "description": "Time analytics for Claude Code — see how much time you spent in each project.",
  "type": "module",
  "bin": {
    "cctime": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --banner '#!/usr/bin/env node' && chmod +x dist/index.js",
    "dev": "bun run src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "time-tracking",
    "analytics"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
